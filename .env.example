# Copy to .env and fill in your tokens. .env is gitignored.
#
# TestPyPI token (https://test.pypi.org/manage/account/token/):
#   create one scoped to project "gbrs-clinical" once the package exists,
#   or scope=Entire account for the first upload.
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-REPLACE_WITH_TESTPYPI_TOKEN
TWINE_REPOSITORY_URL=https://test.pypi.org/legacy/

# For real PyPI uploads, swap to:
#   TWINE_REPOSITORY_URL=https://upload.pypi.org/legacy/
#   TWINE_PASSWORD=pypi-REPLACE_WITH_PYPI_TOKEN
